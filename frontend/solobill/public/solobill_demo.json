        "content": "invoiceNumber,invoiceDate,clientName,projectName,contractingRate,dateDesc,workDesc,lineType,hours,amount\n{% for invoice in invoices -%}\n{% for item in invoice.lineItems -%}\n{{ invoice.invoiceNumber }},{{ invoice.invoiceDate }},\"{{ invoice.client.name }}\",\"{{ invoice.project.name }}\",{{ invoice.project.contractingRate }},\"{{ item.dateDesc }}\",\"{{ item.workDesc }}\",\"detail\",{{ item.hours }},{{ item.hours * invoice.project.contractingRate }}\n{% endfor -%}\n{{ invoice.invoiceNumber }},{{ invoice.invoiceDate }},\"{{ invoice.client.name }}\",\"{{ invoice.project.name }}\",{{ invoice.project.contractingRate }},\"\",\"\",\"summary\",{{ invoice.totalHours }},{{ invoice.totalAmount }}\n{% endfor -%}",
        "isDefault": true,
        "isActive": true,
        "createdAt": 1767623194320,
        "updatedAt": 1767623194320
      },
      {
        "id": "default-email",
        "name": "System Default Email",
        "type": "email",
        "content": "{% set first = invoices[0] -%}\n{% set client = first.client -%}\n{% set consultant = first.consultant -%}\n{% set subject -%}Please find Invoices for {{ consultant.name }}{% endset -%}\n{% set body -%}Hello {{ client.billingRepName | default('Billing Team') }},\n\nPlease find the following invoice{% if invoices | length > 1 %}s{% endif %} attached for services rendered {% if client.name %}to {{ client.name }}{% endif %}:\n\n{% for inv in invoices %}\n- Invoice #{{ inv.invoiceNumber }}\n  Date: {{ inv.invoiceDate | formatDate }}{% if inv.project.poNumber %}\n  PO: {{ inv.project.poNumber }}{% endif %}\n{% endfor %}\n\nBest regards,\n{{ consultant.name }}\n{{ consultant.email }}\n{% endset -%}\nmailto:{{ client.billingRepEmail | urlencode }}?subject={{ subject | urlencode }}&body={{ body | urlencode }}",
        "isDefault": true,
        "isActive": true,
        "createdAt": 1767623194319,
        "updatedAt": 1767623194319
      },
      {
        "id": "default-invoice",
        "name": "System Default Invoice",
        "type": "invoice",
        "content": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <title>Invoice #{{ invoice.invoiceNumber }}</title>\n    <style>\n        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; margin: 0; padding: 0; color: #333; line-height: 1.6; }\n        .invoice-box { max-width: 800px; margin: auto; padding: 40px; }\n        .header { display: flex; justify-content: space-between; margin-bottom: 40px; border-bottom: 2px solid #1976d2; padding-bottom: 20px; }\n        .consultant-info { text-align: right; }\n        .consultant-info h2 { margin: 0; color: #1976d2; }\n        .consultant-info p { margin: 2px 0; font-size: 0.9em; }\n        \n        .bill-to { margin-bottom: 20px; }\n        .bill-to h3 { margin: 2px 0; color: #666; text-transform: uppercase; letter-spacing: 1px; font-weight: bold; }\n        .bill-to h4 { margin: 2px 0; }\n        .bill-to p { margin: 2px 0; font-size: 0.9em; }\n        \n        .details-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; margin-bottom: 40px; }\n        .invoice-meta { text-align: left; }\n        .invoice-meta p { margin: 5px 0; }\n        \n        .project-highlight { background: #f0f7ff; padding: 20px; border-radius: 8px; margin-bottom: 30px; border-left: 4px solid #1976d2; }\n        .project-highlight h4 { margin: 0 0 10px 0; color: #1976d2; text-transform: uppercase; font-size: 0.85em; }\n        \n        table { width: 100%; border-collapse: collapse; margin-bottom: 40px; }\n        th { background: #1976d2; color: white; text-align: left; padding: 12px; font-size: 0.9em; }\n        td { padding: 12px; border-bottom: 1px solid #eee; }\n        tr:last-child td { border-bottom: none; }\n        \n        .totals-section { display: flex; justify-content: flex-end; }\n        .totals-box { width: 250px; }\n        .total-row { display: flex; justify-content: space-between; padding: 8px 0; }\n        .grand-total { border-top: 2px solid #333; margin-top: 10px; padding-top: 15px; font-weight: bold; font-size: 1.2em; color: #1976d2; }\n        \n        @media print {\n            body { padding: 0; }\n            .invoice-box { padding: 0; max-width: 100%; }\n        }\n    </style>\n</head>\n<body>\n    <div class=\"invoice-box\">\n        <div class=\"header\">\n            <div>\n                <h1 style=\"color: #1976d2; margin: 0; font-size: 2.5em;\">INVOICE</h1>\n                <div class=\"invoice-meta\">\n                    <p><strong>Invoice #:</strong> {{ invoice.invoiceNumber }}</p>\n                    <p><strong>Date:</strong> {{ invoice.invoiceDate | formatDate }}</p>\n                    <p><strong>PO #:</strong> {{ invoice.project.poNumber }}</p>\n                </div>\n            </div>\n            <div class=\"consultant-info\">\n                <h2>{{ invoice.consultant.name }}</h2>\n                <p>{{ invoice.consultant.addressL1 }}</p>\n                <p>{{ invoice.consultant.addressL2 }}</p>\n                {% set c_addr3 = invoice.consultant.addressL3 if invoice.consultant.addressL3 is defined else '' %}\n                {% if c_addr3 %}<p>{{ c_addr3 }}</p>{% endif %}\n            </div>\n        </div>\n\n        <div class=\"details-grid\">\n            <div class=\"bill-to\">\n                <h3>BILL TO:</h3>\n                <h4>{{ invoice.client.name }}</h4>\n                <p>{{ invoice.client.addressL1 }}\n                <p>{{ invoice.client.addressL2 }}</p>\n                <p>\n                    {% set cl_addr3 = invoice.client.addressL3 if invoice.client.addressL3 is defined else '' %}\n                    {% if cl_addr3 %}{{ cl_addr3 }}{% endif %}\n                </p>\n            </div>\n\n        </div>\n\n        <div class=\"project-highlight\">\n            <h4>Service Description</h4>\n            <p style=\"margin: 0; font-weight: bold; font-size: 1.1em;\">{{ invoice.project.contractingTitle }}</p>\n            {% set b_desc = invoice.project.billDescription %}\n            {% if b_desc %}\n            <p style=\"margin: 10px 0 0 0; font-size: 0.9em; color: #555;\">{{ b_desc }}</p>\n            {% endif %}\n            <p style=\"margin: 10px 0 0 0; font-size: 0.9em;\"><strong>Rate:</strong> ${{ invoice.project.contractingRate }}/hr</p>\n            <p style=\"margin: 10px 0 0 0; font-size: 0.9em;\"><strong>Project:</strong> {{ invoice.project.name }}</p>\n        </div>\n\n        <table>\n            <thead>\n                <tr>\n                    <th>Date</th>\n                    <th>Description</th>\n                    <th style=\"text-align: right;\">Hours</th>\n                    <th style=\"text-align: right;\">Amount</th>\n                </tr>\n            </thead>\n            <tbody>\n                \n                {% for item in invoice.lineItems %}\n                <tr>\n                    <td>{{ item.dateDesc }}</td>\n                    <td>{{ item.workDesc }}</td>\n                    <td style=\"text-align: right;\">{{ item.hours }}</td>\n                    <td style=\"text-align: right;\">{{ (item.hours * invoice.project.contractingRate) | currency }}</td>\n                </tr>\n                {% endfor %}\n            </tbody>\n        </table>\n\n        <div class=\"totals-section\">\n            <div class=\"totals-box\">\n                <div class=\"total-row\">\n                    <span>Total Hours:</span>\n                    <span>{{ invoice.totalHours }}</span>\n                </div>\n                <div class=\"total-row grand-total\">\n                    <span>Amount Due:</span>\n                    <span>{{ invoice.totalAmount | currency }}</span>\n                </div>\n            </div>\n        </div>\n        <div style=\"margin-top: 40px; font-size: 0.95em; color: #555;\">\n            <p style=\"margin: 0;\">\n                <strong>Make all checks payable to {{ invoice.consultant.name }}</strong>\n            </p>\n\n            {% set term_days = invoice.consultant.additionalFields.termDays | default(30) %}\n            <p style=\"margin: 5px 0 0 0;\">\n                Total due in {{ term_days }} Days.\n            </p>\n        </div>\n\n    </div>\n</body>\n</html>\n",
        "isDefault": true,
        "isActive": true,
        "createdAt": 1767623194316,
        "updatedAt": 1767623194316
      }
    ],
